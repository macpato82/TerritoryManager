#include "VersionNum"

; --- Identity ---------------------------------------------------------------
title-string:          TerritoryManager
help-string:           TerritoryManager Module_MajorVersion_CMHG Module_MinorVersion_CMHG
date-string:           Module_Date_CMHG

; --- Module entry points ----------------------------------------------------
initialisation-code:   mod_init
finalisation-code:     mod_final

; Service handling: AutoDST re-checks on RTC sync, and timezone-name matching
; for *Configure <zone> via the unknown-configuration service.
;   0xDD = Service_RTCSynchronised, 0x28 = Service_UKConfig
service-call-handler:  mod_service 0xDD 0x28

; Generic veneer for the OS_CallAfter callback that performs the DST switch.
generic-veneers:       daylight_switchover_entry/daylight_switchover \
                       daylight_deferred_entry/daylight_deferred

; --- SWIs -------------------------------------------------------------------
; Territory SWIs live in the system SWI range; chunk base is &43040.
; A single central handler (territory_swi) dispatches by SWI offset to the
; per-SWI C functions (c/dispatch).  The decode table is names-only and its
; ORDER IS THE ABI - do not reorder.  Reserved slots 36..52 dispatch to the
; bad-SWI path.
swi-chunk-base-number:  0x43040
swi-handler-code:       territory_swi
swi-decoding-table:     Territory \
    Number Register Deregister NumberToName Exists \
    AlphabetNumberToName SelectAlphabet SetTime ReadCurrentTimeZone \
    ConvertTimeToUTCOrdinals ReadTimeZones ConvertDateAndTime \
    ConvertStandardDateAndTime ConvertStandardDate ConvertStandardTime \
    ConvertTimeToOrdinals ConvertTimeStringToOrdinals ConvertOrdinalsToTime \
    Alphabet AlphabetIdentifier SelectKeyboardHandler WriteDirection \
    CharacterPropertyTable LowerCaseTable UpperCaseTable ControlTable \
    PlainTable ValueTable RepresentationTable Collate ReadSymbols \
    ReadCalendarInformation NameToNumber TransformString IME DaylightRules \
    Reserved1 Reserved2 Reserved3 Reserved4 Reserved5 Reserved6 Reserved7 \
    Reserved8 Reserved9 Reserved10 Reserved11 Reserved12 Reserved13 \
    Reserved14 Reserved15 Reserved16 Reserved17 \
    ConvertTextToString Select DaylightSaving ConvertTimeFormats

; --- *Commands --------------------------------------------------------------
command-keyword-table:  mod_command \
    Territory(min-args: 0, max-args: 1, \
              invalid-syntax: "Syntax: *Territory [<number>|<name>]", \
              help-text: "*Territory selects or reports the current territory.\n"), \
    Territories(min-args: 0, max-args: 0, \
              invalid-syntax: "Syntax: *Territories", \
              help-text: "*Territories lists the registered territories.\n"), \
    DST(min-args: 0, max-args: 0, configure:, status:, \
              help-text: "*Configure DST sets the clock for Daylight Saving Time.\n"), \
    NoDST(min-args: 0, max-args: 0, configure:, \
              help-text: "*Configure NoDST sets the clock for Local Standard Time.\n"), \
    AutoDST(min-args: 0, max-args: 0, configure:, \
              help-text: "*Configure AutoDST lets the computer switch DST itself.\n"), \
    TimeZone(min-args: 0, max-args: 1, configure:, status:, \
              help-text: "*Configure TimeZone sets the offset from UTC.\n")
