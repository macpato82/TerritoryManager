/* Property reason codes (TerritoryManager/hdr/Territory, sequential 0..10). */
#define Property_Control       0
#define Property_Uppercase     1
#define Property_Lowercase     2
#define Property_Alpha         3
#define Property_Punctuation   4
#define Property_Space         5
#define Property_Digit         6
#define Property_XDigit        7
#define Property_Accented      8
#define Property_ForwardFlow   9
#define Property_BackwardFlow  10

/* Lowest / highest valid property reason code. */
#define Property_Min  Property_Control
#define Property_Max  Property_BackwardFlow

/*
 * property_table - return the 256-byte property table for an alphabet+property.
 *
 *   alphabet : alphabet number (e.g. 101 = Latin1).  Currently only Latin1
 *              data exists; every alphabet maps to the Latin1 tables as a
 *              documented best-effort fallback.
 *   property : one of Property_Control .. Property_BackwardFlow.
 *
 * Returns a pointer to a static 256-byte table, or NULL if the property reason
 * code is out of range (caller should then raise Err_UnknownProperty).
 */
const unsigned char *property_table(int alphabet, int property)
{
    (void)alphabet;   /* only Latin1 data available; used as universal fallback */

    switch (property)
    {
        case Property_Control:      return prop_control_latin1;
        case Property_Uppercase:    return prop_uppercase_latin1;
        case Property_Lowercase:    return prop_lowercase_latin1;
        case Property_Alpha:        return prop_alpha_latin1;
        case Property_Punctuation:  return prop_punctuation_latin1;
        case Property_Space:        return prop_space_latin1;
        case Property_Digit:        return prop_digit_latin1;
        case Property_XDigit:       return prop_xdigit_latin1;
        case Property_Accented:     return prop_accented_latin1;
        case Property_ForwardFlow:  return prop_forwardflow_latin1;
        case Property_BackwardFlow: return prop_backwardflow_latin1;
        default:                    return NULL;
    }
}
