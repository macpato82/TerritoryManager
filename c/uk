/* ----------------------------------------------------------------------
 * Timezones (s/UK tz_table: one zone GMT/BST).
 * ---------------------------------------------------------------------- */

/* DST: last Sun Mar 01:00 GMT -> last Sun Oct 01:00 (BST end).
   Source: Resources/UK/Territory token Z00_20??:0100_L1_03-0100_L1_10 */
static const territory_dst_rule uk_dst =
{ 3, 5, 1, 0, 60,  10, 5, 1, 0, 60 };

/* NB: timezone names are named arrays, not inline string literals.  Inline
   string-literal initialisers for struct-pointer fields are not relocated
   reliably in this module (they read back empty); pointers to named static
   objects relocate correctly.  Same pattern applied to name/formats below. */
static const char uk_tz_gmt[] = "GMT";
static const char uk_tz_bst[] = "BST";

static const territory_timezone uk_timezones[1] =
{
    /* GMT std = UTC+0, BST dst = UTC+60min */
    { 0, 60, uk_tz_gmt, uk_tz_bst, &uk_dst }
};

