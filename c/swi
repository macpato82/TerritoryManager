/* Reserved Territory SWIs are handled by the central dispatcher (c/dispatch),
 * which returns the cmhg-provided error_BAD_SWI; no local handler is needed. */

/* Territory_Number  (&43040 + 0)
 *   asm SWITerritory_Number:
 *     Entry: -
 *     Exit:  R0 = configured (current) territory number.
 */
_kernel_oserror *swi_number(int swi, _kernel_swi_regs *r, void *pw)
{
    /* Spec (Doc/SWIs): returns the CONFIGURED territory's number (TerritoryCMOS
       &18).  Fall back to the current selection if CMOS holds no known
       territory (e.g. unset). */
    _kernel_swi_regs cr;
    int terr = 0;
    (void)swi; (void)pw;
    cr.r[0] = 161;            /* OsByte_ReadCMOS */
    cr.r[1] = 0x18;           /* TerritoryCMOS   */
    if (_kernel_swi(OS_Byte, &cr, &cr) == NULL)
        terr = cr.r[2] & 0xFF;
    r->r[0] = (terr != 0 && registry_find(terr) != NULL) ? terr
                                                         : registry_current();
    return NULL;
}

/* Territory_Register (+1)
 *   asm SWITerritory_Register:
 *     Entry: R0 = territory number,
 *            R1 -> buffer holding the list of SWI entry points,
 *            R2 = the territory module's R12 (workspace) value.
 *     Exit:  registers preserved.
 *
 * In this all-C rewrite a territory is described by a territory_data table
 * rather than an entry-point list + private workspace, so the manager registers
 * the structure pointed to by R1.  R0/R2 (number, workspace) are implicit in /
 * not needed by the C contract: the number lives in territory_data.number and
 * there is no separate asm workspace.
 */
_kernel_oserror *swi_register(int swi, _kernel_swi_regs *r, void *pw)
{
    /* The classic Territory_Register ABI passes R1 = a list of SWI entry-point
       addresses for a *delegating* territory module.  This consolidated rewrite
       carries all of its territories built-in and never delegates, so it must
       NOT treat R1 as a territory_data pointer: an old asm territory module
       (e.g. the ROM "UK" module) registering would otherwise inject a bogus
       entry and crash anything that walks the registry (*Territories, etc.).
       Accept the call and ignore it - our own territories are registered
       internally at initialisation. */
    (void)swi; (void)r; (void)pw;
    return NULL;
}

/* Territory_Deregister (+2)
 *   asm SWITerritory_Deregister:
 *     Entry: R0 = territory number.
 *     Exit:  registers preserved.  (asm silently returns if not found.)
 */
_kernel_oserror *swi_deregister(int swi, _kernel_swi_regs *r, void *pw)
{
    (void)swi; (void)pw;
    return registry_deregister(r->r[0]);
}

/* Territory_NumberToName (+3)
 *   asm SWITerritory_NumberToName:
 *     Entry: R0 = territory number,
 *            R1 -> buffer,
 *            R2 = length of buffer.
 *     Exit:  buffer filled with the territory name (NUL terminated);
 *            registers preserved; UnknownTerritory error if not present.
 *
 * The asm looks the name up via MessageTrans into [R1] for at most R2 bytes;
 * we copy territory_data.name with the same truncate-and-NUL-terminate rule and
 * leave R0/R1/R2 unchanged.
 */
_kernel_oserror *swi_numbertoname(int swi, _kernel_swi_regs *r, void *pw)
{
    const territory_data *f = registry_find(registry_resolve(r->r[0]));
    char *buf  = (char *)r->r[1];
    int   size = r->r[2];
    int   i = 0;
    const char *s;

    (void)swi; (void)pw;

    if (f == NULL)
        return Err_BadTerritory;

    s = f->name;
    while (i < size - 1 && s[i] != '\0')
    {
        buf[i] = s[i];
        i++;
    }
    if (size > 0)
        buf[i] = '\0';
    return NULL;
}

/* Territory_Exists (+4)
 *   asm SWITerritory_Exists:
 *     Entry: R0 = territory number.
 *     Exit:  R0 preserved; Z set if the territory is currently loaded, clear if
 *            not.  No error is ever returned (an absent territory is not an
 *            error - it is reported through the flag).
 *
 * The asm reports presence purely through the PSR Z flag.  A CMunge C SWI
 * veneer is handed a _kernel_swi_regs block (R0..R9 only) and has no access to
 * the returned PSR, so the raw Z-flag convention cannot be reproduced from C.
 * We keep the asm's no-error / R0-preserved behaviour and report presence in
 * R1 (0 = absent, 1 = present); the assembler-thunk generated by CMunge maps
 * the C return into the SWI exit.
 */
_kernel_oserror *swi_exists(int swi, _kernel_swi_regs *r, void *pw)
{
    int exists = 0;
    _kernel_oserror *e;

    (void)swi; (void)pw;

    e = registry_exists(r->r[0], &exists);
    if (e != NULL)
        return e;
    r->r[1] = exists ? 1 : 0;
    return NULL;
}

/* Territory_NameToNumber (+32)
 *   This SWI is dispatched into the territory module by the asm (entry-point
 *   based); the documented ABI is:
 *     Entry: R1 -> name string.
 *     Exit:  R0 = territory number.
 */
_kernel_oserror *swi_nametonumber(int swi, _kernel_swi_regs *r, void *pw)
{
    const char           *name = (const char *)r->r[1];
    const territory_data *f    = registry_find_by_name(name);

    (void)swi; (void)pw;

    /* Spec (Doc/SWIs): "R0 = 0 if territory unknown, else number" - an unknown
       name is NOT an error.  Returning an error here breaks callers (e.g. the
       Country configuration / International path) that expect R0 = 0. */
    r->r[0] = (f != NULL) ? f->number : 0;
    return NULL;
}

/* Territory_Select (+54)
 *   asm SWITerritory_Select:
 *     Entry: R0 = new territory number.
 *     Exit:  -  (TerritoryNotPresent error if the territory is not loaded).
 */
_kernel_oserror *swi_select(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror *e;
    (void)swi;
    e = registry_select(r->r[0]);
    if (e != NULL)
        return e;
    /* A new territory may use different timezones: re-assess DST and announce
       the change (Service_TerritoryStarted = &75). */
    (void)daylight_switch_check(pw);
    (void)_swix(OS_ServiceCall, _INR(0,1), 0, 0x75);
    return NULL;
}

