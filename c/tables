/* ------------------------------------------------------------------------
 * Territory_AlphabetNumberToName  (chunk +5)
 *   Entry: R0 = alphabet number, R1 -> buffer, R2 = buffer length.
 *   Exit:  [R1] = name of the alphabet ("Alphabet<n>"-style token lookup).
 *
 * NOTE: this SWI is keyed on an ALPHABET number, not a territory number, and
 * the asm resolved it via a messages-file token ("A<number>").  The frozen
 * contract has no alphabet-name registry, so we synthesise a stable
 * "Alphabet<n>" string as a best effort.
 * TODO-verify: original produced messages-file token "A<n>"; confirm desired
 * text and whether a real alphabet-name table belongs in the contract.
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_alphabetnumbertoname(int swi, _kernel_swi_regs *r, void *pw)
{
    int   alphabet = r->r[0];
    char *buf      = (char *)r->r[1];
    int   size     = r->r[2];
    char  tmp[32];
    int   n, i;

    /* Build "Alphabet<n>" without using any float / library locale. */
    {
        static const char prefix[] = "Alphabet";
        int p = 0;
        while (prefix[p] != '\0' && p < (int)sizeof(tmp) - 12)
        {
            tmp[p] = prefix[p];
            p++;
        }
        n = alphabet;
        if (n < 0)
        {
            tmp[p++] = '-';
            n = -n;
        }
        {
            char rev[12];
            int  k = 0;
            do { rev[k++] = (char)('0' + (n % 10)); n /= 10; } while (n != 0);
            while (k > 0)
                tmp[p++] = rev[--k];
        }
        tmp[p] = '\0';
    }

    i = 0;
    if (buf != NULL && size > 0)
    {
        while (i < size - 1 && tmp[i] != '\0')
        {
            buf[i] = tmp[i];
            i++;
        }
        buf[i] = '\0';
    }
    return NULL;
}

/* ------------------------------------------------------------------------
 * Territory_SelectAlphabet  (chunk +6)
 *   Entry: R0 = territory number or -1.
 *   Exit:  registers preserved; the territory's default alphabet is selected.
 * (asm SWITerritory_SelectAlphabet: reads the alphabet via Territory_Alphabet,
 *  then OS_Byte 71,128+alphabet to make it current, then Service_International
 *  Inter_Define to (re)define the character range.  Here we issue the OS_Byte;
 *  the service call is left for the module's service layer.)
 * TODO-verify: original also issued Service_International Inter_Define for
 * chars 0..255 after selecting; wire that in when the service layer lands.
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_selectalphabet(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror      *err = NULL;
    const territory_data *t   = registry_require(r->r[0], &err);
    _kernel_swi_regs      ob;
    if (t == NULL)
        return err ? err : Err_BadTerritory;

    ob.r[0] = OsByte_Alphabet;
    ob.r[1] = 128 + t->default_alphabet;   /* >=128 => select that alphabet */
    ob.r[2] = 0;
    return _kernel_swi(OS_Byte, &ob, &ob);
}

