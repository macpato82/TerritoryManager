/* ------------------------------------------------------------------------
 * Territory_CharacterPropertyTable  (chunk +22)
 *   Entry: R0 = territory number or -1, R1 = property reason code (0..10).
 *   Exit:  R0 -> 256-byte table for that property (1 byte per char: nonzero
 *          if the char has the property).
 *
 * The asm Entries (CharacterPropertyTable) selected one of eleven distinct
 * tables by the R1 reason code (ControlTable, UppercaseTable, ...,
 * BackwardFlowTable) and returned its address in R0, or raised
 * TerritoryError_UnknownProperty for any other reason.  We reproduce that
 * exactly via property_table(), keyed on the territory's default alphabet.
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_charpropertytable(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror      *err = NULL;
    const territory_data *t   = registry_require(r->r[0], &err);
    int                   prop = r->r[1];
    const unsigned char  *table;
    if (t == NULL)
        return err ? err : Err_BadTerritory;

    table = property_table(t->default_alphabet, prop);
    if (table == NULL)
        return Err_UnknownProperty;   /* asm: TerritoryError_UnknownProperty */

    r->r[0] = (int)table;
    return NULL;
}

