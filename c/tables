/* ------------------------------------------------------------------------
 * Territory_ReadSymbols  (chunk +30)
 *   Entry: R0 = territory number or -1, R1 = reason code (0..18).
 *   Exit:  R0 = requested value: a POINTER for the string/grouping reasons
 *          (0..9, 18) or an INTEGER for the numeric reasons (10..17).
 * (asm Entries: "ReadSymbols" indexes SymbolTable by R1; entries <20 are
 *  numeric, >=20 are offsets that become pointers.)
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_readsymbols(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror         *err = NULL;
    const territory_data    *t   = registry_require(r->r[0], &err);
    int                      reason = r->r[1];
    const territory_symbols *s;
    if (t == NULL)
        return err ? err : Err_BadTerritory;

    s = &t->symbols;
    switch (reason)
    {
        case Symbol_DecimalPoint:    r->r[0] = (int)s->decimal_point;     break;
        case Symbol_ThousandsSep:    r->r[0] = (int)s->thousands_sep;     break;
        case Symbol_Grouping:        r->r[0] = (int)s->grouping;          break;
        case Symbol_IntCurrSymbol:   r->r[0] = (int)s->int_curr_symbol;   break;
        case Symbol_CurrencySymbol:  r->r[0] = (int)s->currency_symbol;   break;
        case Symbol_MonDecimalPoint: r->r[0] = (int)s->mon_decimal_point; break;
        case Symbol_MonThousandsSep: r->r[0] = (int)s->mon_thousands_sep; break;
        case Symbol_MonGrouping:     r->r[0] = (int)s->mon_grouping;      break;
        case Symbol_PositiveSign:    r->r[0] = (int)s->positive_sign;     break;
        case Symbol_NegativeSign:    r->r[0] = (int)s->negative_sign;     break;
        case Symbol_IntFracDigits:   r->r[0] = s->int_frac_digits;        break;
        case Symbol_FracDigits:      r->r[0] = s->frac_digits;            break;
        case Symbol_PCsPrecedes:     r->r[0] = s->p_cs_precedes;          break;
        case Symbol_PSepBySpace:     r->r[0] = s->p_sep_by_space;         break;
        case Symbol_NCsPrecedes:     r->r[0] = s->n_cs_precedes;          break;
        case Symbol_NSepBySpace:     r->r[0] = s->n_sep_by_space;         break;
        case Symbol_PSignPosn:       r->r[0] = s->p_sign_posn;            break;
        case Symbol_NSignPosn:       r->r[0] = s->n_sign_posn;            break;
        case Symbol_ListSymbol:      r->r[0] = (int)s->list_symbol;       break;
        default:
            /* asm had no bounds check (out-of-range reads were UB); we reject
             * an unknown reason code with the standard bad-SWI error. */
            return (_kernel_oserror *)&tables_error_BAD_SWI;
    }
    return NULL;
}

/* ------------------------------------------------------------------------
 * Territory_ReadCalendarInformation  (chunk +31)
 *   Entry: R0 = territory number or -1,
 *          R1 -> 5-byte UTC time value,
 *          R2 -> 12-word output buffer.
 *   Exit:  R1,R2 preserved; buffer filled:
 *          [R2+0]  first working day      [R2+24] max W3 (short day) length
 *          [R2+4]  last working day       [R2+28] max DY (day-of-month) length
 *          [R2+8]  number of months       [R2+32] max ST (suffix) length
 *          [R2+12] days in current month   [R2+36] max MO (full month) length
 *          [R2+16] max AM/PM length        [R2+40] max M3 (short month) length
 *          [R2+20] max WE (full day) length[R2+44] max TZ length
 *
 * (asm GetCalendarInformation: copies the 11 fixed CalendarInfo words into
 *  slots 0,1,2 then 4..11, then computes [R2+12] = days-in-current-month from
 *  the UTC time in R1.  That month-length computation needs date decoding the
 *  contract doesn't yet provide here, so it is left as TODO-verify.)
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_readcalendarinformation(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror          *err = NULL;
    const territory_data     *t   = registry_require(r->r[0], &err);
    int                      *buf = (int *)r->r[2];
    const territory_calendar *c;
    if (t == NULL)
        return err ? err : Err_BadTerritory;
    if (buf == NULL)
        return Err_BadTerritory;   /* TODO-verify: asm assumed a valid buffer */

    c = &t->calendar;
    buf[0]  = c->first_work_day;
    buf[1]  = c->last_work_day;
    buf[2]  = c->num_months;
    /* buf[3] = days in current month - depends on R1 (the UTC time). */
    buf[4]  = c->max_ampm_len;
    buf[5]  = c->max_fullday_len;
    buf[6]  = c->max_shortday_len;
    buf[7]  = c->max_day_len;
    buf[8]  = c->max_suffix_len;
    buf[9]  = c->max_fullmonth_len;
    buf[10] = c->max_shortmonth_len;
    buf[11] = c->max_tz_len;

    /* TODO-verify: compute buf[3] = number of days in the month containing the
     * UTC time at r->r[1], honouring leap years (asm used MonthLengths + the
     * 4/100/400 rule).  Requires a date-decode helper not yet wired into the
     * C rewrite; defaulting to a safe upper bound for now. */
    buf[3]  = 31;

    return NULL;
}

/* ------------------------------------------------------------------------
 * Territory_TransformString  (chunk +33)
 *   Entry: R0 = territory number or -1,
 *          R1 = destination buffer,
 *          R2 = source string (0-terminated),
 *          R3 = destination buffer length.
 *   Exit:  R0 = length of the transformed string (excluding terminator).
 *          If that length >= R3-on-entry the buffer contents are
 *          indeterminate.  If R3 == 0, R1 may be NULL.
 *
 * (asm Transform: produces a collation key such that a byte-wise comparison of
 *  two transformed strings orders them as Territory_Collate would.  The asm
 *  uses SortValueTable / ToLowerTable / ToPlainForCollateTable plus ligature
 *  rules.  The contract exposes `collate` (a weight table) but not the
 *  lower/plain-for-collate tables nor the per-territory ligature flags, so a
 *  faithful key cannot be built generically yet.)
 *
 * Best-effort: build a single-pass key using the collate weight table when
 * present (weight per byte), else a case/accent-folded key via lower_case and
 * plain.  This preserves "equal/ordering" for the common Latin1 case but is
 * NOT the exact asm multi-pass key.
 * TODO-verify: reproduce the asm's 3x-length escaped key (letters, then
 * accents, then case) and ligature expansion.  Needs SortValueTable,
 * ToLowerTable and ToPlainForCollateTable plus the Collate* flags in the
 * contract (see "missing fields").
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_transformstring(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror      *err = NULL;
    const territory_data *t   = registry_require(r->r[0], &err);
    char                 *dst = (char *)r->r[1];
    const unsigned char  *src = (const unsigned char *)r->r[2];
    int                   dstlen = r->r[3];
    const unsigned char  *weight;
    const unsigned char  *lower;
    const unsigned char  *plain;
    int                   out = 0;
    int                   i;

    if (t == NULL)
        return err ? err : Err_BadTerritory;

    weight = t->collate;
    lower  = t->lower_case;
    plain  = t->plain;

    /* First pass: compute the output length. */
    for (i = 0; src[i] != '\0'; i++)
        out++;

    /* Length excludes the terminator (matches asm R0 semantics). */
    if (out >= dstlen)
    {
        r->r[0] = out;            /* not enough room; buffer indeterminate */
        return NULL;
    }

    for (i = 0; i < out; i++)
    {
        unsigned char ch = src[i];
        if (plain != NULL)  ch = plain[ch];   /* strip accent  */
        if (lower != NULL)  ch = lower[ch];   /* fold case     */
        if (weight != NULL) ch = weight[ch];  /* collation weight */
        dst[i] = (char)ch;
    }
    if (dstlen > 0)
        dst[out] = '\0';

    r->r[0] = out;
    return NULL;
}

/* ------------------------------------------------------------------------
 * Territory_IME  (chunk +34)
 *   Entry: R0 = territory number or -1.
 *   Exit:  R0 = the IME SWI chunk for this territory (0 if none).
 * (asm Entries: "IME" -> LDR r0,=IMESWIChunk; territories with no IME supply
 *  a chunk of 0.)  The contract now carries ime_chunk, so we return it
 *  directly; 0 means "this territory has no IME".
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_ime(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror      *err = NULL;
    const territory_data *t   = registry_require(r->r[0], &err);
    if (t == NULL)
        return err ? err : Err_BadTerritory;

    r->r[0] = t->ime_chunk;   /* IME SWI chunk; 0 => no IME */
    return NULL;
}
