/* OS_Byte 71 - select/read alphabet & keyboard (asm OsByte_Alphabet). */
#define OsByte_Alphabet  71

/* SWI number for OS_Byte (in case the toolchain headers do not define it). */
#ifndef OS_Byte
#define OS_Byte  0x06
#endif

/* The asm SWI decoder answered an out-of-range SWI reason code with the
 * standard "bad SWI" error (Territory_SWIdecode -> ErrorNumber_OutOfRange,
 * &1E6).  c/swi keeps its own file-static copy; we mirror it here for the
 * few table SWIs that validate a sub-reason code. */
#ifndef ErrorNumber_BadSWI
#define ErrorNumber_BadSWI  0x1E6
#endif
static const _kernel_oserror tables_error_BAD_SWI =
    { ErrorNumber_BadSWI, "Unknown Territory operation" };

/* ------------------------------------------------------------------------
 * Territory_Alphabet  (chunk +18)
 *   Entry: R0 = territory number or -1.
 *   Exit:  R0 = default alphabet number for that territory.
 * (asm Entries: "Alphabet" -> MOV r0,#AlphNum)
 * ------------------------------------------------------------------------ */
_kernel_oserror *swi_alphabet(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror      *err = NULL;
    const territory_data *t   = registry_require(r->r[0], &err);
    if (t == NULL)
        return err ? err : Err_BadTerritory;

    r->r[0] = t->default_alphabet;
    return NULL;
}

