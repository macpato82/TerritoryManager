/* ========================================================================= */
/* SWI Territory_ConvertTextToString  (manager SWI, &43040 + 53).             */
/*  This is the inverse of ConvertDateAndTime: it parses ordinals from a      */
/*  block and a format, producing a string.  In practice the asm form drives  */
/*  the same %-expansion engine but takes its ordinals from a 36-byte block   */
/*  pointed to by R1 (already decomposed) rather than a 5-byte time, so no     */
/*  timezone conversion is performed.                                         */
/*  In:  R1 -> ordinal block, R2 -> buffer, R3 = size(+flags),                */
/*       R4 -> format string.                                                 */
/*  Out: R0 = buffer, R1 -> terminator, R3 adjusted.                          */
/* ========================================================================= */
_kernel_oserror *swi_converttexttostring(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror *err = NULL;
    const territory_data *t = registry_require(-1, &err);
    unsigned flags = (unsigned)r->r[3];
    const char *fmt = (const char *)r->r[4];
    const int *blk = (const int *)r->r[1];
    int bufsize;
    ord o;
    char *endp; int freeb;
    (void)swi; (void)pw;

    if (t == NULL) return err;
    if (fmt == NULL) return Err_BadTimeString;

    if (flags & DAT_FlagExtension)
    {
        if (flags & DAT_ReservedMask) return Err_BadTimeString;
        bufsize = (int)(flags & 0xFFFF);
    }
    else
    {
        bufsize = r->r[3];                 /* old API: whole R3 is the size */
    }

    /* Take the ordinals straight from the supplied block. */
    o.cs    = blk[0];
    o.sec   = blk[1];
    o.min   = blk[2];
    o.hour  = blk[3];
    o.dom   = blk[4];
    o.month = blk[5];
    o.year  = blk[6];
    o.dow   = blk[7];
    o.doy   = blk[8];
    o.woy   = 0;
    /* Derive dow/doy/woy if not provided (block may be a 28-byte form). */
    if (o.dow < 1 || o.dow > 7 || o.doy < 1)
    {
        ord d;
        t5  c;
        if (compose(&o, &c) == 0)
        {
            decompose(c, &d);
            o.dow = d.dow; o.doy = d.doy; o.woy = d.woy;
        }
    }

    err = expand_format(t, &o, "", fmt, (char *)r->r[2], bufsize, &endp, &freeb);
    if (err != NULL) return err;

    r->r[0] = r->r[2];                     /* buffer pointer */
    r->r[1] = (int)endp;                   /* terminator */
    r->r[2] = freeb;                       /* bytes free in buffer */
    if (flags & DAT_FlagExtension)
        r->r[3] = (int)(flags & ~DAT_FlagExtension);
    else
        r->r[3] = r->r[4];
    return NULL;
}

/* ========================================================================= */
/* SWI Territory_ConvertTimeStringToOrdinals                                  */
/*  In: R1 = reason, R2 -> string, R3 -> ordinal buffer.                      */
/*  Parses fixed forms; missing fields set to -1.  Mirrors the asm.           */
/* ========================================================================= */

static const char *skip_spaces(const char *s) { while (*s==' ') s++; return s; }

static int read_int(const char **s, int maxval)
{
    const char *p = *s;
    int v = 0, any = 0;
    while (*p >= '0' && *p <= '9') { v = v*10 + (*p - '0'); p++; any = 1; }
    if (!any || v > maxval) return -1;
    *s = p;
    return v;
}

_kernel_oserror *swi_converttimestringtoordinals(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror *err = NULL;
    const territory_data *t = registry_require(-1, &err);
    const territory_calendar *cal;
    int   reason = r->r[1];
    const char *s = (const char *)r->r[2];
    int  *b = (int *)r->r[3];
    (void)swi; (void)pw;

    if (t == NULL) return err;
    cal = &t->calendar;

    s = skip_spaces(s);

    /* date part */
    if (reason & CTS_Date)
    {
        int dom, mon = -1, year, i, ndigits;
        const char *ys;
        /* optional "Www, " day-of-week prefix: skip up to and incl first ',' */
        if (!(*s >= '0' && *s <= '9'))
        {
            while (*s && *s != ',') s++;
            if (*s == ',') s++;
            s = skip_spaces(s);
        }
        dom = read_int(&s, 31);
        if (dom <= 0) return Err_BadTimeString;
        s = skip_spaces(s);
        if (*s == '-') { s++; s = skip_spaces(s); }

        /* match month name (case-insensitive prefix) against short names */
        if (cal->month_short)
        {
            for (i = 0; i < cal->num_months; i++)
            {
                const char *mn = cal->month_short[i];
                const char *ss = s;
                int ok = (mn != NULL);
                while (ok && *mn)
                {
                    int a = (unsigned char)*mn, c = (unsigned char)*ss;
                    if (a>='A'&&a<='Z') a += 32;
                    if (c>='A'&&c<='Z') c += 32;
                    if (a != c) ok = 0;
                    mn++; ss++;
                }
                if (ok) { mon = i + 1; break; }
            }
        }
        if (mon < 0) return Err_BadTimeString;
        /* skip rest of alpha month, then separator */
        while (*s && *s != ' ' && *s != '-') s++;
        if (*s) s++;
        s = skip_spaces(s);

        ys = s;
        year = read_int(&s, 0x7FFFFFFF);
        if (year < 0) return Err_BadTimeString;
        ndigits = (int)(s - ys);
        if (ndigits < 3)
        {
            /* 2-digit year: pivot on 26-Jan-66 (asm rule). */
            year += 2000;
            if (year > 2000 + 66 ||
                (year == 2066 && (mon > 1 || (mon == 1 && dom >= 26))))
                year -= 100;
        }

        b[4] = dom;
        b[5] = mon;
        b[6] = year;
        if (*s == '.') { s++; }
        s = skip_spaces(s);
    }
    else
    {
        b[4] = b[5] = b[6] = -1;
    }

    /* time part */
    if (reason & CTS_Time)
    {
        int hh, mm, ss2;
        b[0] = 0;                     /* centiseconds */
        hh = read_int(&s, 24); if (hh < 0) return Err_BadTimeString;
        s = skip_spaces(s); if (*s == ':') { s++; s = skip_spaces(s); }
        mm = read_int(&s, 59); if (mm < 0) return Err_BadTimeString;
        s = skip_spaces(s); if (*s == ':') { s++; s = skip_spaces(s); }
        ss2 = read_int(&s, 61); if (ss2 < 0) return Err_BadTimeString;
        b[3] = hh; b[2] = mm; b[1] = ss2;
    }
    else
    {
        b[0] = b[1] = b[2] = b[3] = -1;
    }
    return NULL;
}

/* ========================================================================= */
/* SWI Territory_DaylightRules  (private; R1=0 supported, R1=1 get bounds).   */
/*  R1=0: V=0,R0=1 supported; (asm uses V to say "no" - here R0=1 always as   */
/*        we can always evaluate a rule when one is present).                 */
/*  R1=1: R2 = timezone within territory, R3 = year, R4 -> start 5-byte,      */
/*        R5 -> end 5-byte.  V=0 rule matched; error (Err_NoRuleDefined) if   */
/*        no rule for this territory/zone.                                    */
/* ========================================================================= */
_kernel_oserror *swi_daylightrules(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror *err = NULL;
    const territory_data *t;
    (void)swi; (void)pw;

    if (r->r[1] > 1)
        return Err_BadSubreason;

    if (r->r[1] == 0)
    {
        /* "Supported": yes if we have any timezone with a DST rule. */
        int std, i, supported = 0;
        t = registry_require(-1, &err);
        if (t == NULL) return err;
        if (t->timezones)
            for (i = 0; i < t->num_timezones; i++)
                if (t->timezones[i].dst_rule != NULL) { supported = 1; break; }
        (void)std;
        r->r[0] = supported;
        return NULL;
    }

    /* Get bounds for a year. */
    {
        int tz_index = r->r[2];
        int year     = r->r[3];
        int std_off  = 0;
        const territory_dst_rule *rule;

        t = registry_require(-1, &err);
        if (t == NULL) return err;

        rule = find_rule(t, tz_index, &std_off);
        if (rule == NULL)
            return Err_NoRuleDefined;

        {
            t5 start = rule_instant(year, rule->start_month, rule->start_week,
                                    rule->start_dow, rule->start_dom,
                                    rule->start_time, std_off);
            t5 stop  = rule_instant(year, rule->end_month, rule->end_week,
                                    rule->end_dow, rule->end_dom,
                                    rule->end_time, std_off);
            write5((unsigned char *)r->r[4], start);
            write5((unsigned char *)r->r[5], stop);
        }
        return NULL;
    }
}

/* ========================================================================= */
/* SWI Territory_DaylightSaving  (R0=territory, R1=subreason).                */
/* ========================================================================= */

/* Read the configured DST CMOS bits into DaylightSaving_* form. */
static int dst_read_state(void)
{
    int out = 0;
    if (dst_active())     out |= DST_DSTBit;
    if (autodst_active()) out |= DST_AutoDSTBit;
    return out;
}

/* Write the DST CMOS bits from DaylightSaving_* form, mirroring the asm:
   when auto is enabled the explicit DST bit is preserved (auto manages it). */
static void dst_write_state(int want)
{
    int alarm = read_cmos(CMOS_AlarmAndTime);
    int dbtb  = read_cmos(CMOS_DBTB);

    if (want & DST_AutoDSTBit)
        dbtb |= AutoDSTCMOSBit;
    else
    {
        dbtb &= ~AutoDSTCMOSBit;
        /* not auto: set/clear the manual DST bit explicitly */
        if (want & DST_DSTBit) alarm |=  DSTCMOSBit;
        else                   alarm &= ~DSTCMOSBit;
        write_cmos(CMOS_AlarmAndTime, alarm);
    }
    write_cmos(CMOS_DBTB, dbtb);
}

/* Given the start/stop UTC instants and a query instant, decide whether DST
   is in force, handling both hemispheres.  Returns DST_DSTBit or 0. */
static int dst_in_window(t5 start, t5 stop, t5 query)
{
    int hemi = 0;                          /* hemisphere adjustment */
    if (stop < start)
    {
        /* southern hemisphere: swap so start<stop, invert sense */
        t5 tmp = start; start = stop; stop = tmp;
        hemi = DST_DSTBit;
    }
    {
        int in = (query >= start && query <= stop) ? DST_DSTBit : 0;
        return in ^ hemi;
    }
}

_kernel_oserror *swi_daylightsaving(int swi, _kernel_swi_regs *r, void *pw)
{
    int reason = r->r[1];
    (void)swi;

    switch (reason)
    {
    case DST_ReadState:
        r->r[0] = dst_read_state();
        return NULL;

    case DST_WriteState:
        dst_write_state(r->r[2]);
        return NULL;

    case DST_Supported:
    {
        _kernel_swi_regs rr = *r;
        _kernel_oserror *e;
        rr.r[1] = 0;                       /* DaylightRules: supported? */
        e = swi_daylightrules(swi, &rr, pw);
        if (e != NULL) { r->r[0] = 0; return NULL; }   /* asm: V->R0=0 */
        r->r[0] = rr.r[0];
        return NULL;
    }

    case DST_ApplyOrd:
    case DST_ApplyTime:
    {
        /* Build the query UTC instant and the year from R3's block. */
        t5  query;
        int year;
        ord o;
        const unsigned char *blk = (const unsigned char *)r->r[3];

        if (reason == DST_ApplyOrd)
        {
            block_to_ord((const int *)r->r[3], &o);
            if (compose(&o, &query) != 0)
                return Err_BadTimeBlock;
            year = o.year;
        }
        else
        {
            query = read5(blk);
            decompose(query, &o);
            year = o.year;
        }

        /* Get this year's bounds via DaylightRules. */
        {
            _kernel_swi_regs rr;
            unsigned char startb[5], stopb[5];
            _kernel_oserror *e;
            rr.r[0] = r->r[0];
            rr.r[1] = 1;                    /* get bounds */
            rr.r[2] = -1;                   /* current timezone */
            rr.r[3] = year;
            rr.r[4] = (int)startb;
            rr.r[5] = (int)stopb;
            e = swi_daylightrules(swi, &rr, pw);
            if (e != NULL)
            {
                r->r[0] = 0;               /* no rule -> standard time */
                return NULL;
            }
            r->r[0] = dst_in_window(read5(startb), read5(stopb), query);
        }
        return NULL;
    }

    case DST_GetBounds:
    {
        /* R0=territory, R2=timezone, R3=year(-1=this year), R4/R5 -> blocks. */
        int year = r->r[3];
        _kernel_swi_regs rr;
        _kernel_oserror *e;

        if (year == -1)
        {
            /* "this year": read the RTC and decompose.  OS_Word 14 reason 3
               returns the 5-byte UTC integer starting at byte 0 of the block
               (overwriting the reason byte). */
            unsigned char block[8];
            _kernel_swi_regs w;
            ord o;
            block[0] = 3;                   /* request 5-byte UTC */
            block[1] = block[2] = block[3] = block[4] = 0;
            w.r[0] = 14;                    /* OsWord_ReadRealTimeClock */
            w.r[1] = (int)block;
            e = _kernel_swi(OS_Word, &w, &w);
            if (e != NULL) return e;
            decompose(read5(block), &o);
            year = o.year;
        }

        rr.r[0] = r->r[0];
        rr.r[1] = 1;                        /* get bounds */
        rr.r[2] = r->r[2];                  /* timezone within territory */
        rr.r[3] = year;
        rr.r[4] = r->r[4];
        rr.r[5] = r->r[5];
        e = swi_daylightrules(swi, &rr, pw);
        if (e != NULL)
            return Err_NoRuleDefined;       /* asm remaps to NoRuleDefined */
        return NULL;
    }

    default:
        return Err_BadSubreason;
    }
}

/* ========================================================================= */
/* SWI Territory_ConvertTimeFormats  (manager SWI, &43040 + 56).              */
/*  The central UTC<->local converter (asm s/SWIs ConvertTimeFormats).        */
/*  In:  R0 = territory (or -1), R1 -> input block, R2 -> output block,       */
/*       R3 = format + flags, R4 = timezone-within-territory or cs offset.    */
/*   format: b0-7 = input, b8-15 = output; 0=local ord, 1=local 5byte,        */
/*           2=UTC ord, 3=UTC 5byte.                                          */
/*   flags:  b16 DST, b17 use-std-if-no-auto, b18 use-auto-DST,               */
/*           b19 = R4 is a signed cs offset rather than a timezone index.     */
/*  Input ordinals need only the 28-byte form; output ordinals are 36-byte.   */
/* ========================================================================= */
#define TF_InShift              0
#define TF_OutShift             8
#define TF_Flag_DST             (1u<<16)
#define TF_Flag_UseStdIfNoAuto  (1u<<17)
#define TF_Flag_UseAutoDST      (1u<<18)
#define TF_Flag_SpecifyOffset   (1u<<19)

_kernel_oserror *swi_converttimeformats(int swi, _kernel_swi_regs *r, void *pw)
{
    _kernel_oserror *err = NULL;
    const territory_data *t;
    unsigned flags  = (unsigned)r->r[3];
    int      infmt  = (int)((flags >> TF_InShift)  & 0xFF);
    int      outfmt = (int)((flags >> TF_OutShift) & 0xFF);
    int      in_utc, out_utc, out_ord;
    t5       time5;
    ord      o;
    (void)swi;

    /* Only b0-1 of each format byte are meaningful, and no flags above b19. */
    if ((flags >> 20) != 0 || (infmt & 0xFC) != 0 || (outfmt & 0xFC) != 0)
        return Err_BadSubreason;

    in_utc  = (infmt  & 2) != 0;
    out_utc = (outfmt & 2) != 0;
    out_ord = (outfmt & 1) == 0;

    /* Read input into a 5-byte time in its own (local or UTC) frame. */
    if (infmt & 1)
    {
        time5 = read5((const unsigned char *)r->r[1]);
    }
    else
    {
        block_to_ord((const int *)r->r[1], &o);
        if (compose(&o, &time5) != 0)
            return Err_BadTimeBlock;
    }

    /* Localisation is only needed when the input and output frames differ. */
    if (in_utc != out_utc)
    {
        int offset_cs;

        if (flags & TF_Flag_SpecifyOffset)
        {
            if (flags & (TF_Flag_UseAutoDST | TF_Flag_UseStdIfNoAuto))
                return Err_BadSubreason;     /* incompatible with raw offset */
            offset_cs = r->r[4];
            if (flags & TF_Flag_DST)
                offset_cs += TICKS_PER_HOUR; /* assume DST is a fixed +1h */
        }
        else
        {
            int tz_index = r->r[4];
            const territory_timezone *tz;

            t = registry_require(r->r[0], &err);
            if (t == NULL) return err;
            if (t->timezones == NULL || tz_index < 0 ||
                tz_index >= t->num_timezones)
                return Err_NoMoreZones;
            tz = &t->timezones[tz_index];

            /* Auto DST: let DaylightSaving decide on/off for this instant. */
            if (flags & TF_Flag_UseAutoDST)
            {
                unsigned char tb[5];
                _kernel_swi_regs dr;
                write5(tb, time5);
                dr.r[0] = r->r[0];
                dr.r[1] = DST_ApplyTime;
                dr.r[3] = (int)tb;
                err = swi_daylightsaving(0, &dr, pw);
                if (err != NULL)
                {
                    if (!(flags & TF_Flag_UseStdIfNoAuto))
                        return err;
                    dr.r[0] = 0;             /* pretend standard time */
                }
                if (dr.r[0] & DST_DSTBit) flags |=  TF_Flag_DST;
                else                      flags &= ~TF_Flag_DST;
            }

            offset_cs = ((flags & TF_Flag_DST) ? tz->dst_offset_min
                                               : tz->std_offset_min)
                        * TICKS_PER_MINUTE;
        }

        /* local = UTC + offset.  UTC->local adds, local->UTC subtracts. */
        if (in_utc && !out_utc)
            time5 += offset_cs;
        else
            time5 -= offset_cs;
    }

    /* Write output (ordinals are the full 36-byte form). */
    if (out_ord)
    {
        decompose(time5, &o);
        ord_to_block(&o, (int *)r->r[2]);
    }
    else
    {
        write5((unsigned char *)r->r[2], time5);
    }
    return NULL;
}
