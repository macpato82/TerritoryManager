/* A calendar era (e.g. Japanese Heisei/Reiwa) for %JE/%J1/%JY formatting.
   Defined early because territory_calendar refers to it. */
typedef struct territory_era
{
    int         start_year;   /* Gregorian year the era began */
    int         start_month;  /* 1..12 */
    int         start_dom;    /* day of month */
    char        name[40];     /* full era name */
    char        abbrev[20];   /* short era name */
} territory_era;

/* Territory_ReadSymbols - the C-locale lconv equivalent (asm SymbolTable). */
typedef struct territory_symbols
{
    /* These are inline char arrays, not pointers: inline string-literal
       initialisers for pointer fields do not relocate reliably in this module
       (they read back empty/garbage), whereas data stored inline in the struct
       needs no relocation.  See the same change across the other structs. */
    char        decimal_point[8];
    char        thousands_sep[8];
    char        grouping[8];
    char        int_curr_symbol[12];
    char        currency_symbol[16];
    char        mon_decimal_point[8];
    char        mon_thousands_sep[8];
    char        mon_grouping[8];
    char        positive_sign[8];
    char        negative_sign[8];
    int         int_frac_digits;
    int         frac_digits;
    int         p_cs_precedes;
    int         p_sep_by_space;
    int         n_cs_precedes;
    int         n_sep_by_space;
    int         p_sign_posn;
    int         n_sign_posn;
    char        list_symbol[8];
} territory_symbols;

/* Territory_ReadCalendarInformation (asm CalendarInfo: 11 fixed words) plus the
 * name tables that the asm pulled from the messages file. */
typedef struct territory_calendar
{
    int first_work_day;     /* 1=Sun .. 7=Sat */
    int last_work_day;
    int num_months;
    int max_ampm_len;
    int max_fullday_len;    /* MaxWELength */
    int max_shortday_len;   /* MaxW3Length */
    int max_day_len;        /* MaxDYLength */
    int max_suffix_len;     /* MaxSTLength (st/nd/rd/th) */
    int max_fullmonth_len;  /* MaxMOLength */
    int max_shortmonth_len; /* MaxM3Length */
    int max_tz_len;         /* MaxTZLength */

    const char *const *month_full;   /* [num_months] */
    const char *const *month_short;  /* [num_months] */
    const char *const *day_full;     /* [7], index 0 = Sunday */
    const char *const *day_short;    /* [7] */
    char        am_string[24];     /* e.g. Turkish "\xF6\xF0leden \xF6nce" */
    char        pm_string[24];
    const char *const *ordinal_suffix; /* by day-of-month 1..31, or rule-based */

    const territory_era *eras;         /* calendar eras (Japan); NULL if none */
    int                  num_eras;
} territory_calendar;

/* A daylight-saving transition rule (when DST starts/ends).  NULL => no DST. */
typedef struct territory_dst_rule
{
    int start_month;   /* 1..12 */
    int start_week;    /* 1..5 (5 = last), or 0 if start_dom used */
    int start_dow;     /* 1=Sun..7=Sat, or 0 */
    int start_dom;     /* day-of-month, or 0 if week/dow used */
    int start_time;    /* local minutes after midnight of the transition */
    int end_month;
    int end_week;
    int end_dow;
    int end_dom;
    int end_time;
} territory_dst_rule;

/* One timezone entry (asm tz_table: $offstd, $offdst pairs + names). */
typedef struct territory_timezone
{
    int         std_offset_min;   /* minutes east of UTC, standard time */
    int         dst_offset_min;   /* minutes east of UTC, daylight time */
    char        std_name[16];
    char        dst_name[16];
    const territory_dst_rule *dst_rule;  /* NULL => DST never applies */
} territory_timezone;

/* A complete territory definition. */
typedef struct territory_data
{
    int         number;             /* e.g. 1 = UK */
    char        name[40];           /* "UK", "USA", ... (matches NameToNumber) */

    int         default_alphabet;   /* alphabet number (e.g. 101 = Latin1) */
    char        alphabet_name[20];  /* AlphabetIdentifier string */
    int         keyboard;           /* SelectKeyboardHandler number */
    int         write_direction;    /* WriteDirection flags */
    int         ime_chunk;          /* Territory_IME SWI chunk (0 if none) */

    /* 256-entry tables for the default alphabet (Territory_*Table SWIs).
       Any may be NULL, in which case the Manager uses the identity/global. */
    const unsigned char *lower_case;
    const unsigned char *upper_case;
    const unsigned char *control;
    const unsigned char *plain;
    const unsigned char *value;
    const unsigned char *representation;
    const unsigned char *property;     /* CharacterPropertyTable */
    const unsigned char *collate;      /* weight table; NULL => byte compare */

    territory_symbols    symbols;
    territory_calendar   calendar;

    const territory_timezone *timezones;
    int                       num_timezones;

    /* Default format strings for Territory_ConvertDateAndTime (%-style, as the
       asm stored). */
    char        date_format[48];
    char        time_format[32];
    char        datetime_format[80];
} territory_data;

